<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>.dockerignore</title>
    <style>
        .code-container {
            background-color: #1e1e1e;
            color: #d4d4d4;
            padding: 15px;
            border-radius: 8px;
            font-family: 'Courier New', monospace;
            position: relative;
            margin: 20px 0;
        }
        .copy-btn {
            position: absolute;
            top: 10px;
            right: 10px;
            background-color: #007acc;
            color: white;
            border: none;
            padding: 5px 12px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 12px;
        }
        .copy-btn:hover {
            background-color: #005a9e;
        }
        pre {
            margin: 0;
            white-space: pre-wrap;
            word-wrap: break-word;
        }
    </style>
</head>
<body>
<div class="code-container">
    <button class="copy-btn" onclick="copyCode()">Копия кардан</button>
    <pre id="codeBlock">
# backend/.dockerignore - Файлҳое, ки ба Docker image дохил намешаванд

# Вобастагиҳо
node_modules
npm-debug.log
yarn-error.log

# Логҳо
logs
*.log

# Файлҳои муҳити зист
.env
.env.local
.env.production
.env.development

# Директорияҳои билд ва вақтинӣ
dist
build
tmp
temp
coverage
.nyc_output

# Директорияҳои тест
tests
test
__tests__
*.test.ts
*.spec.ts
jest.config.js

# Файлҳои IDE ва Editor
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
.editorconfig

# Git
.git
.gitignore
.gitattributes

# Docker
Dockerfile
.dockerignore
docker-compose*.yml

# CI/CD
.github
.gitlab-ci.yml
.travis.yml

# Документатсия
README.md
CHANGELOG.md
CONTRIBUTING.md
docs

# Дигар
*.tar.gz
*.zip
.vercel
.netlify
    </pre>
</div>
<script>
function copyCode() {
    const code = document.getElementById('codeBlock').innerText;
    navigator.clipboard.writeText(code).then(() => {
        alert('Код копия карда шуд!');
    }).catch(() => {
        alert('Хатогӣ ҳангоми копия кардан');
    });
}
</script>
</body>
</html>
