<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>.env.example</title>
    <style>
        .code-container {
            background-color: #1e1e1e;
            color: #d4d4d4;
            padding: 15px;
            border-radius: 8px;
            font-family: 'Courier New', monospace;
            position: relative;
            margin: 20px 0;
        }
        .copy-btn {
            position: absolute;
            top: 10px;
            right: 10px;
            background-color: #007acc;
            color: white;
            border: none;
            padding: 5px 12px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 12px;
        }
        .copy-btn:hover {
            background-color: #005a9e;
        }
        pre {
            margin: 0;
            white-space: pre-wrap;
            word-wrap: break-word;
        }
    </style>
</head>
<body>
<div class="code-container">
    <button class="copy-btn" onclick="copyCode()">Копия кардан</button>
    <pre id="codeBlock">
# ============================================
# Tojrason Delivery System - Environment Variables
# ============================================
# Ин файлро ҳамчун .env нусхабардорӣ кунед ва қиматҳои воқеиро ворид кунед
# cp .env.example .env

# ============================================
# Node.js
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# Database (PostgreSQL)
# ============================================
# Барои коркарди маҳаллӣ бо Docker:
# DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/tojrason"
# Барои коркарди маҳаллӣ бе Docker:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/tojrason"
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/tojrason"

# ============================================
# Redis (Cache & Queue)
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# JWT Authentication
# ============================================
# Барои истеҳсолӣ, рамзи қавӣ истифода баред (min 32 characters)
JWT_SECRET="your-super-secret-jwt-key-change-me-in-production"
JWT_EXPIRES_IN="7d"

# ============================================
# Logging
# ============================================
# Сатҳҳо: error, warn, info, http, verbose, debug, silly
LOG_LEVEL="info"

# ============================================
# Security (CORS, Rate Limit)
# ============================================
# Барои доменҳои серверҳои frontend
CORS_ORIGIN="http://localhost:3000,http://localhost:5173,http://localhost:5000"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Stripe Payment
# ============================================
# Аз https://dashboard.stripe.com/apikeys гиред
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"

# ============================================
# Email (Nodemailer / SMTP)
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@tojrason.com"

# ============================================
# SMS (Eskiz.uz / Twilio)
# ============================================
# Барои Eskiz.uz
SMS_API_KEY="your-sms-api-key"
SMS_SENDER="Tojrason"
SMS_API_URL="https://notify.eskiz.uz/api"

# ============================================
# Push Notifications (Firebase Cloud Messaging)
# ============================================
FCM_SERVER_KEY="your-fcm-server-key"

# ============================================
# Frontend URLs (барои redirect пас аз пардохт)
# ============================================
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3001"
COURIER_URL="http://localhost:3002"

# ============================================
# Docker Compose (барои истеҳсолӣ)
# ============================================
# Дар муҳити Docker, ин қиматҳоро тағйир диҳед
# DATABASE_URL="postgresql://postgres:postgres123@postgres:5432/tojrason"
# REDIS_URL="redis://redis:6379"
    </pre>
</div>
<script>
function copyCode() {
    const code = document.getElementById('codeBlock').innerText;
    navigator.clipboard.writeText(code).then(() => {
        alert('Код копия карда шуд!');
    }).catch(() => {
        alert('Хатогӣ ҳангоми копия кардан');
    });
}
</script>
</body>
</html>
