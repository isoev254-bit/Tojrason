# Tojrason/frontend/courier/.env.example
# © 2024 Тоҷрасон. Ҳамаи ҳуқуқҳо маҳфузанд.
# Ин файл қисми нармафзори "Тоҷрасон" мебошад.
# Истифодаи ғайриқонунии ин файл ё қисмҳои он тибқи қонунгузории Ҷумҳурии Тоҷикистон таъқиб карда мешавад.
#
# Барои истифодаи тағйирёбандаҳо дар муҳити таҳиявӣ, ин файлро ба .env.local нусхабардорӣ кунед
# ва қиматҳои воқеии худро ворид кунед.
# Ҳаргиз файли .env-ро бо маълумоти ҳассос ба Git ворид накунед!

# =============================================
# API ТАНЗИМОТ
# =============================================
# URL-и асосии API барои дархостҳои HTTP
VITE_API_URL=http://localhost:5000/api
# URL-и WebSocket барои пайвастшавии вақти воқеӣ
VITE_WS_URL=ws://localhost:5000

# =============================================
# МАЪЛУМОТИ БАРНОМА
# =============================================
# Номи барнома (дар сарлавҳаҳо ва унвонҳо истифода мешавад)
VITE_APP_NAME=Тоҷрасон Курйер
# Версияи барнома
VITE_APP_VERSION=1.0.0
# Муҳити барнома: development, staging, production
VITE_APP_ENV=development
# Фаъол кардани режими курйер
VITE_COURIER_APP=true

# =============================================
# КАЛИДҲОИ API-И ХИЗМАТРАСОНИҲОИ БЕРУНӢ
# =============================================
# Калиди API барои харитаҳои Google (ихтиёрӣ, агар истифода нашавад, OpenStreetMap истифода мешавад)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# =============================================
# МОНИТОРИНГ ВА ХАТОГИРӢ
# =============================================
# DSN барои Sentry (ихтиёрӣ, танҳо дар production истифода шавад)
VITE_SENTRY_DSN=

# =============================================
# ХУСУСИЯТҲОИ ТАҲИЯВӢ
# =============================================
# Фаъол/ғайрифаъол кардани API-и санҷишӣ (Mock API) барои таҳия бидуни бэкенд
VITE_ENABLE_MOCK=false
